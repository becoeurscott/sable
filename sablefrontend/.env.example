# Copy to .env.local (local dev) or set these in Vercel → Settings → Environment Variables.
# NOTE: NEXT_PUBLIC_* vars are inlined at BUILD time — after changing them in
# Vercel you must trigger a redeploy for the new value to take effect.

# REQUIRED — base URL of the FinanceAI backend (Railway/Render), including /api/v1.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# OPTIONAL — only if you want Supabase Auth (Google OAuth / magic links) in the
# browser. Leave unset to use the backend's own email/password auth (AUTH_MODE=local).
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
