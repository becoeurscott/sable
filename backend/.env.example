# ─────────────────────────────────────────────────────────────
# FinanceAI backend — environment configuration
# Copy to .env and fill in. NEVER commit real secrets (§12 Secrets Mgmt).
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000
# Comma-separated list of allowed browser origins (CORS)
CORS_ORIGINS=http://localhost:3000

# ── Database ──
# LOCAL (docker-compose):
DATABASE_URL=postgres://financeai:financeai@localhost:5432/financeai
DB_RLS_ROLE=app_authenticated
DATABASE_SSL=auto            # auto | on | off  (auto = SSL for non-localhost)
#
# SUPABASE: grab the connection string from your project →
#   Settings → Database → Connection string → "URI" (use the Pooler / port 6543).
#   Then set (the local auth shim is skipped automatically, SSL turns on):
# DATABASE_URL=postgresql://postgres.nzdmcksdgqhnmhthfsdn:YOUR-DB-PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres
# DB_RLS_ROLE=authenticated

# ── Auth ──
# local    = the app issues its own JWTs (default)
# supabase = verify Supabase Auth JWTs (requires SUPABASE_JWT_SECRET)
AUTH_MODE=local
JWT_SECRET=change-me-dev-only-supersecret-please-rotate
JWT_ACCESS_TTL=3600            # seconds (1h, per §12)
JWT_REFRESH_TTL=2592000        # seconds (30d)
# For AUTH_MODE=supabase (Settings → API):
SUPABASE_URL=https://nzdmcksdgqhnmhthfsdn.supabase.co
SUPABASE_JWT_SECRET=           # Settings → API → JWT Secret

# ── Stripe billing (§2, §10) — optional; billing endpoints degrade if unset ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Gemma AI (§4) — optional; AI degrades to heuristics if unset ──
# Option 1: Google AI Studio
GEMMA_API_KEY=
GEMMA_MODEL=gemma-3-27b-it
# Option 2: OpenRouter (takes precedence if set). Get a key at openrouter.ai/keys.
# Models: google/gemma-3-27b-it · google/gemma-2-9b-it · try a ':free' variant to start.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-27b-it

# ── Email (Resend, §13/§14) — optional; invoice send is logged (not emailed) if unset ──
RESEND_API_KEY=
EMAIL_FROM=FinanceAI <onboarding@resend.dev>

# ── Master developer key (optional) ──
# Full cross-org API access without login/membership — for YOUR own scripts/admin.
# Generate: node -e "console.log('sbl_admin_'+require('crypto').randomBytes(32).toString('hex'))"
# Send as X-API-Key or Bearer, with X-Org-Id to pick the org. Keep secret.
ADMIN_API_KEY=

# ── Rate limiting store ──
# memory (default, single-node) | redis (set REDIS_URL for multi-node, §15)
RATE_LIMIT_STORE=memory
REDIS_URL=
